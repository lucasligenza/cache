VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key      # web-push reminders
VITE_ANTHROPIC_API_KEY=your-anthropic-key        # reserved for AI sort (deferred, not wired)

# Optional error telemetry. Leave blank to disable (the reporter is inert).
# When set, uncaught errors + React crashes are POSTed as JSON to this collector
# (your own endpoint, a serverless function, a Sentry tunnel, etc.).
VITE_ERROR_REPORT_URL=
VITE_RELEASE=                                    # optional build/commit id tag on reports
